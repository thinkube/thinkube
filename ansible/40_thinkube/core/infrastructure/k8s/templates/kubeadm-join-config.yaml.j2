apiVersion: kubeadm.k8s.io/v1beta4
kind: JoinConfiguration
discovery:
  bootstrapToken:
    token: "{{ join_token }}"
    apiServerEndpoint: "{{ hostvars[control_plane_host]['lan_ip'] }}:6443"
    caCertHashes:
      - "{{ join_ca_cert_hash }}"
nodeRegistration:
  criSocket: "unix:///run/containerd/containerd.sock"
  imagePullSerial: true
