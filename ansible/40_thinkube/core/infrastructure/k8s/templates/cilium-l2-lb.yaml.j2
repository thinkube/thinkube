# Cilium L2 Load Balancer pool + announcement policy.
# Rendered by 10_install_k8s.yaml on the control plane (both overlay modes).
#
# Replaces the k8s-snap `k8s enable load-balancer` + `k8s set load-balancer.cidrs=...`
# command pair. Same outcome — Cilium claims VIPs from the named range via
# ARP on the configured interfaces — using upstream Cilium CRDs directly.

---
apiVersion: "cilium.io/v2alpha1"
kind: CiliumLoadBalancerIPPool
metadata:
  name: thinkube-lb-pool
spec:
  blocks:
    - start: "{{ lb_ip_range_start }}"
      stop: "{{ lb_ip_range_end }}"

---
apiVersion: "cilium.io/v2alpha1"
kind: CiliumL2AnnouncementPolicy
metadata:
  name: thinkube-l2-announce
spec:
  loadBalancerIPs: true
  interfaces:
    - "^en[0-9].*"
    - "^eth[0-9].*"
    - "^wl.*"
    - "^bond.*"
  nodeSelector:
    matchLabels:
      kubernetes.io/os: linux
