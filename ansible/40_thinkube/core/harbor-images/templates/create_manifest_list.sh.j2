#!/bin/bash
set -e
# Create and push multi-arch manifest lists for {{ image_name }}
# Uses docker:// transport to reference per-arch images from Harbor
# so locally-absent images (skipped during incremental builds) still work.
{% for tag in image_tags %}
podman manifest rm {{ image_name }}:{{ tag }} 2>/dev/null || true
podman rmi {{ image_name }}:{{ tag }} 2>/dev/null || true
podman manifest create {{ image_name }}:{{ tag }} \
{% for arch in arch_build_nodes.keys() %}
  docker://{{ image_name }}:{{ image_tags[0] }}-{{ arch }}{{ ' \\' if not loop.last else '' }}
{% endfor %}

podman manifest push --tls-verify=true \
  {{ image_name }}:{{ tag }} \
  docker://{{ image_name }}:{{ tag }}
{% endfor %}
