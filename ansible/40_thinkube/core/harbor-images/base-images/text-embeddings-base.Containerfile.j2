# Text Embeddings Inference base image with Gradio and MLflow dependencies
# Architecture-aware: uses sm_121 on arm64 (DGX Spark), sm_86 on amd64 (Ampere)
ARG BASE_IMAGE={{ harbor_registry }}/library/text-embeddings-inference:121-latest
FROM ${BASE_IMAGE}

WORKDIR /app

# Install Python and pip (TEI base may not have them)
USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Add dependencies for Thinkube embeddings serving templates
RUN pip3 install --no-cache-dir --break-system-packages \
    gradio>=4.42.0 \
    mlflow~=3.6.0 \
    httpx>=0.27.0 \
    numpy \
    requests \
    uvicorn

# Create icons directory
RUN mkdir -p /app/icons
