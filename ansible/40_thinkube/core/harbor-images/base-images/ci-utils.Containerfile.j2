# Lightweight CI/CD utilities image with curl and common tools
FROM library/alpine:latest

# Install commonly needed CI/CD tools
RUN apk add --no-cache \
    # Essential tools
    curl \
    wget \
    git \
    bash \
    # JSON/YAML processing
    jq \
    yq \
    # Text processing (grep, sed, awk are in busybox)
    # Network tools
    openssh-client \
    ca-certificates \
    # Build essentials
    make \
    # Archive tools (tar, gzip in busybox)
    unzip && \
    # Install crane for container registry manifest manipulation
    ARCH=$(uname -m) && \
    case "$ARCH" in aarch64) CRANE_ARCH=arm64 ;; *) CRANE_ARCH=x86_64 ;; esac && \
    curl -sL "https://github.com/google/go-containerregistry/releases/latest/download/go-containerregistry_Linux_${CRANE_ARCH}.tar.gz" | tar xz -C /usr/local/bin crane && \
    chmod +x /usr/local/bin/crane

# Add a non-root user for security
RUN adduser -D -s /bin/bash ci-user

# Set bash as default shell
SHELL ["/bin/bash", "-c"]

# Create workspace directory
WORKDIR /workspace

# Default to non-root user
USER ci-user

# Health check command
HEALTHCHECK NONE

# Default command
CMD ["/bin/bash"]