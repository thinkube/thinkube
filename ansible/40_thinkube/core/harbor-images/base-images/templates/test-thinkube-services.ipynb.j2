    "print_section(\"ArgoCD\")\n",
    "\n",
    "argocd_server = os.environ.get('ARGOCD_GRPC_URL')\n",
    "argocd_token = os.environ.get('ARGOCD_AUTH_TOKEN')\n",
    "\n",
    "if not argocd_server:\n",
    "    print_skip(\"ArgoCD not configured (optional - ARGOCD_GRPC_URL not set)\")\n",
    "else:\n",
    "    try:\n",
    "        import grpc\n",
    "        from argocd_client import ApplicationServiceStub, ApplicationQuery\n",
    "    except ImportError:\n",
    "        # Fall back to grpc channel health check\n",
    "        try:\n",
    "            import grpc\n",
    "            \n",
    "            if not argocd_token:\n",
    "                print_error(\"ArgoCD token not set (ARGOCD_AUTH_TOKEN required)\")\n",
    "            else:\n",
    "                # Create gRPC channel with TLS\n",
    "                credentials = grpc.ssl_channel_credentials()\n",
    "                call_credentials = grpc.access_token_call_credentials(argocd_token)\n",
    "                composite = grpc.composite_channel_credentials(credentials, call_credentials)\n",
    "                \n",
    "                channel = grpc.secure_channel(argocd_server, composite)\n",
    "                \n",
    "                # Use channel connectivity check\n",
    "                try:\n",
    "                    grpc.channel_ready_future(channel).result(timeout=5)\n",
    "                    print_success(f\"Connected to ArgoCD gRPC at {argocd_server}\")\n",
    "                    print_info(\"gRPC channel ready\")\n",
    "                except grpc.FutureTimeoutError:\n",
    "                    print_error(\"ArgoCD gRPC channel not ready (timeout)\")\n",
    "                finally:\n",
    "                    channel.close()\n",
    "        except ImportError:\n",
    "            print_error(\"grpc library not installed\")\n",
    "        except Exception as e:\n",
    "            print_error(f\"ArgoCD connection failed: {str(e)}\")"
   ]
