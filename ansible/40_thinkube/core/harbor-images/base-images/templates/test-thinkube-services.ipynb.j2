    "# Thinkube Services Connection Test\n",
    "\n",
    "This notebook tests connectivity to all Thinkube services and validates that credentials are properly configured.\n",
    "\n",
    "**Test Philosophy:**\n",
    "- All tests perform **actual operations** with credentials, not just endpoint checks\n",
    "- Core services **MUST** be configured - tests will **FAIL** if missing\n",
    "- Optional services are **SKIPPED** if not configured\n",
    "- **NO fallback values** - if a required variable is missing, test fails immediately\n",
    "\n",
    "**Expected Results:**\n",
    "- \u2705 All core services should pass\n",
    "- \u2298 Optional services may be skipped (normal if not deployed)\n",
    "- \u274c Any failures indicate misconfiguration\n",
    "\n",
    "Run all cells to validate your environment setup."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Import required libraries\n",
    "import os\n",
    "import sys\n",
    "import warnings\n",
    "from pathlib import Path\n",
    "from IPython.display import display, HTML\n",
    "\n",
    "# Suppress InsecureRequestWarning for internal services using self-signed certs\n",
    "import urllib3\n",
    "urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)\n",
    "\n",
    "# Set to True when running via MCP/API (plain text output only)\n",
    "MCP_MODE = False\n",
    "\n",
    "# Output helpers — HTML for JupyterLab, plain text for MCP\n",
    "def print_success(msg):\n",
    "    if MCP_MODE: print(f'PASS: {msg}')\n",
    "    else: display(HTML(f'<span style=\"color: #00c896; font-weight: bold;\">\u2705 {msg}</span>'))\n",
    "\n",
    "def print_error(msg):\n",
    "    if MCP_MODE: print(f'FAIL: {msg}')\n",
    "    else: display(HTML(f'<span style=\"color: #e74c3c; font-weight: bold;\">\u274c {msg}</span>'))\n",
    "\n",
    "def print_warning(msg):\n",
    "    if MCP_MODE: print(f'WARN: {msg}')\n",
    "    else: display(HTML(f'<span style=\"color: #ff8c42; font-weight: bold;\">\u26a0\ufe0f  {msg}</span>'))\n",
    "\n",
    "def print_info(msg):\n",
    "    if MCP_MODE: print(f'INFO: {msg}')\n",
    "    else: display(HTML(f'<span style=\"color: #3498db; font-weight: bold;\">\u2139\ufe0f  {msg}</span>'))\n",
    "\n",
    "def print_section(msg):\n",
    "    if MCP_MODE: print(f'\\n=== {msg} ===')\n",
    "    else: display(HTML(f'<h3 style=\"color: #006680; margin-top: 20px;\">{msg}</h3>'))\n",
    "\n",
    "def print_skip(msg):\n",
    "    if MCP_MODE: print(f'SKIP: {msg}')\n",
    "    else: display(HTML(f'<span style=\"color: #95a5a6; font-weight: bold;\">\u2298 {msg}</span>'))"
   ]
