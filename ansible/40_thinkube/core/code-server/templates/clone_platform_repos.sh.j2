#!/bin/bash
# Rendered by Ansible — clones thinkube platform repos into code-server
set -e

echo '===== Cloning platform repositories ====='

CLONE_BRANCH='{{ clone_branch }}'
echo "Target branch: $CLONE_BRANCH"

if [ ! -f /home/thinkube/.ssh/github_ed25519 ]; then
  echo 'ERROR: No SSH key found at /home/thinkube/.ssh/github_ed25519'
  exit 1
fi

chmod 600 /home/thinkube/.ssh/github_ed25519
export GIT_SSH_COMMAND='ssh -i /home/thinkube/.ssh/github_ed25519 -o StrictHostKeyChecking=no'

{% for repo in repos_to_clone %}
# {{ repo.name }} -> {{ repo.category | default('misc') }}/
category='{{ repo.category | default('misc') }}'
repo_name='{{ repo.name }}'
repo_full='{{ repo.full_name }}'

mkdir -p "/home/thinkube/thinkube-platform/$category"

if [ ! -d "/home/thinkube/thinkube-platform/$category/$repo_name" ]; then
  echo "Cloning $repo_full into $category/$repo_name (branch: $CLONE_BRANCH)..."
  git clone -b "$CLONE_BRANCH" "git@github.com:$repo_full.git" \
    "/home/thinkube/thinkube-platform/$category/$repo_name" 2>/dev/null \
  || git clone "git@github.com:$repo_full.git" \
    "/home/thinkube/thinkube-platform/$category/$repo_name"
else
  echo "$category/$repo_name already exists, pulling latest..."
  cd "/home/thinkube/thinkube-platform/$category/$repo_name"
  git reset --hard HEAD
  if git fetch origin 2>&1; then
    if git rev-parse --verify "origin/$CLONE_BRANCH" >/dev/null 2>&1; then
      echo "Resetting to origin/$CLONE_BRANCH for $repo_name..."
      git checkout "$CLONE_BRANCH" 2>/dev/null || git checkout -b "$CLONE_BRANCH" "origin/$CLONE_BRANCH"
      git reset --hard "origin/$CLONE_BRANCH"
    else
      echo "Branch $CLONE_BRANCH not found on origin for $repo_name, using main..."
      git reset --hard origin/main
    fi
  else
    echo "ERROR: Failed to fetch from origin for $repo_name"
    exit 1
  fi
fi
{% endfor %}

echo '✅ All platform repositories cloned'
