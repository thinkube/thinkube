#!/bin/bash
# Rendered by Ansible — clones the Tandem sidecar board repo into code-server.
# The board repo (TEP-0008) is the central methodology board for every Thinking
# Space; the thinkube-ai-integration extension locates it via thinkube.boards.root
# (= /home/thinkube/thinkube-tandem). It lives at the top level, NOT under
# thinkube-platform/<category>/, because it is namespaced by <container>/<rel>.
set -e

board_repo='{{ tandem_board_repo }}'
board_dir='/home/thinkube/thinkube-tandem'

echo "===== Cloning Tandem board repository ($board_repo) ====="

if [ ! -f /home/thinkube/.ssh/github_ed25519 ]; then
  echo 'ERROR: No SSH key found at /home/thinkube/.ssh/github_ed25519'
  exit 1
fi

chmod 600 /home/thinkube/.ssh/github_ed25519
export GIT_SSH_COMMAND='ssh -i /home/thinkube/.ssh/github_ed25519 -o StrictHostKeyChecking=no'

if [ ! -d "$board_dir" ]; then
  echo "Cloning $board_repo into $board_dir..."
  git clone "git@github.com:$board_repo.git" "$board_dir"
else
  echo "$board_dir already exists, pulling latest..."
  cd "$board_dir"
  git reset --hard HEAD
  if git fetch origin 2>&1; then
    default_branch=$(git remote show origin 2>/dev/null | grep 'HEAD branch' | awk '{print $NF}')
    echo "Resetting to origin/$default_branch for the board repo..."
    git reset --hard "origin/$default_branch"
  else
    echo "ERROR: Failed to fetch from origin for the board repo"
    exit 1
  fi
fi

echo '✅ Tandem board repository cloned'
