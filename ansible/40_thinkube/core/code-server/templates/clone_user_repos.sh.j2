#!/bin/bash
# Rendered by Ansible — clones user template repos into code-server
set -e

echo '===== Cloning user template repositories ====='
mkdir -p /home/thinkube/user-templates

if [ ! -f /home/thinkube/.ssh/github_ed25519 ]; then
  echo 'ERROR: No SSH key found at /home/thinkube/.ssh/github_ed25519'
  exit 1
fi

chmod 600 /home/thinkube/.ssh/github_ed25519
export GIT_SSH_COMMAND='ssh -i /home/thinkube/.ssh/github_ed25519 -o StrictHostKeyChecking=no'

{% for tmpl in user_templates_to_clone %}
repo_name='{{ tmpl.name }}'
repo_full='{{ tmpl.full_name }}'

if [ ! -d "/home/thinkube/user-templates/$repo_name" ]; then
  echo "Cloning $repo_full..."
  git clone "git@github.com:$repo_full.git" "/home/thinkube/user-templates/$repo_name"
else
  echo "$repo_name already exists, pulling latest..."
  cd "/home/thinkube/user-templates/$repo_name"
  git reset --hard HEAD
  if git fetch origin 2>&1; then
    default_branch=$(git remote show origin 2>/dev/null | grep 'HEAD branch' | awk '{print $NF}')
    echo "Resetting to origin/$default_branch for $repo_name..."
    git reset --hard "origin/$default_branch"
  else
    echo "ERROR: Failed to fetch from origin for $repo_name"
    exit 1
  fi
fi
{% endfor %}

echo '✅ User template repositories cloned'
